{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListSpecificSecurityLabBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::REPLACE-WITH-YOUR-BUCKET-NAME"
    },
    {
      "Sid": "AllowReadOnlyObjectsInSpecificSecurityLabBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE-WITH-YOUR-BUCKET-NAME/*"
    }
  ]
}
